<launch>
  <arg name="serial_port_path" default="/dev/ttyACM0" />
  <arg name="joint_states_topic" default="/joint_states_host" />
  <arg name="arm_status_topic" default="/arm_status_host" />
  <arg name="eePose_pub_topic" default="/end_effector_pose" />
  <arg name="urdfFile" value="$(find mobiman)/urdf/A1/urdf/A1_URDF_0607_0028.urdf" />
  <arg name="publish_tf" default="true" />

  <!-- Driver only: no tracker/controller node is launched in this file. -->
  <include file="$(find signal_arm)/launch/single_arm_node.launch">
    <arg name="single_arm_serial_port_path" value="$(arg serial_port_path)" />
    <arg name="single_arm_joint_states_topic" value="$(arg joint_states_topic)" />
    <arg name="single_arm_arm_status_topic" value="$(arg arm_status_topic)" />
  </include>

  <!-- FK based EEF pose publisher from joint states. -->
  <node pkg="mobiman" type="eepose_pub_node" name="eePose_pub_node" output="screen">
    <param name="urdfFile" value="$(arg urdfFile)" />
    <param name="ee_frame" value="arm_seg6" />
    <param name="eePose_sub_topic" value="$(arg joint_states_topic)" />
    <param name="eePose_pub_topic" value="$(arg eePose_pub_topic)" />
  </node>

  <param name="robot_description" textfile="$(arg urdfFile)" />

  <node if="$(arg publish_tf)"
        name="robot_state_publisher"
        pkg="robot_state_publisher"
        type="robot_state_publisher">
    <remap from="joint_states" to="$(arg joint_states_topic)" />
  </node>

  <node if="$(arg publish_tf)"
        pkg="tf2_ros"
        type="static_transform_publisher"
        name="world_to_base_link"
        args="0 0 0 0 0 0 world base_link" />
</launch>
